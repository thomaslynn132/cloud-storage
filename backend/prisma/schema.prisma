generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserType {
  ADMIN
  UPLOADER
  DOWNLOADER
}

enum PlanType {
  FREE
  PAID
}

enum PaymentType {
  DURATION
  STORAGE
  SUBSCRIPTION
}

enum PricingType {
  STORAGE_GB      // Price per GB of storage
  RETENTION_DAYS   // Price per day of file retention
}

model User {
  id                    String     @id @default(uuid()) @db.Uuid
  email                 String     @unique @db.VarChar
  passwordHash          String     @db.VarChar
  userType              UserType   @default(UPLOADER)
  planType              PlanType   @default(FREE)
  storageUsed           BigInt     @default(0) // in bytes
  storageLimit          BigInt     @default(26843545600) // 25GB in bytes for free uploaders
  durationLimit         Int        @default(0) // in seconds, 0 means no limit for free
  subscriptionExpiresAt DateTime?
  isActive              Boolean    @default(true)
  createdAt             DateTime   @default(now()) @db.Timestamp(6)
  updatedAt             DateTime   @updatedAt @db.Timestamp(6)
  
  files                 File[]
  payments              Payment[]
  downloads             Download[]
  createdPricingRules   PricingRule[] @relation("Creator")

  @@map("users")
}

model File {
  id            String     @id @default(uuid()) @db.Uuid
  userId        String     @db.Uuid
  fileName      String     @db.VarChar
  size          Int        // in bytes
  duration      Int        @default(0) // in seconds, for media files
  hash          String     @db.VarChar
  storageKey    String     @db.VarChar
  mimeType      String?    @db.VarChar
  isPermanent   Boolean    @default(false)
  expiryDate    DateTime?  @db.Timestamp(6)
  downloadCount Int        @default(0)
  isDeleted     Boolean    @default(false)
  isProcessed   Boolean    @default(false)
  createdAt     DateTime   @default(now()) @db.Timestamp(6)
  updatedAt     DateTime   @updatedAt @db.Timestamp(6)
  
  user          User       @relation(fields: [userId], references: [id])
  downloads     Download[]

  @@index([expiryDate])
  @@index([hash])
  @@index([userId])
  @@map("files")
}

model Payment {
  id                String      @id @default(uuid()) @db.Uuid
  userId            String      @db.Uuid
  amount            Int         // in cents
  paymentType       PaymentType @default(SUBSCRIPTION)
  plan              PlanType?
  retentionDays     Int?        // days to keep file in R2 before deletion
  storageBytes      BigInt?     // bytes of storage purchased
  transactionRef    String?     @db.VarChar
  paymentProof      String?     @db.VarChar // file path to uploaded payment proof image
  status            String      @default("pending") @db.VarChar
  adminNote         String?     @db.VarChar
  processedAt       DateTime?   @db.Timestamp(6)
  expiresAt         DateTime?   @db.Timestamp(6)
  createdAt         DateTime    @default(now()) @db.Timestamp(6)
  updatedAt         DateTime    @updatedAt @db.Timestamp(6)
  
  user              User        @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("payments")
}

model PricingRule {
  id          String      @id @default(uuid()) @db.Uuid
  name        String      @db.VarChar
  type        PricingType
  pricePerUnit Int        // in cents per GB (storage) or per day (retention)
  minUnits    Int         @default(1)
  maxUnits    Int?        // null means unlimited
  isActive    Boolean     @default(true)
  createdById String      @db.Uuid
  createdAt   DateTime    @default(now()) @db.Timestamp(6)
  updatedAt   DateTime    @updatedAt @db.Timestamp(6)
  
  createdBy   User        @relation("Creator", fields: [createdById], references: [id])

  @@map("pricing_rules")
}

model Download {
  id         String   @id @default(uuid()) @db.Uuid
  fileId     String   @db.Uuid
  userId     String?  @db.Uuid // null for anonymous downloaders
  ipAddress  String   @db.VarChar
  userAgent  String?  @db.VarChar
  adShown    Boolean  @default(false)
  adClicked  Boolean  @default(false)
  downloaded Boolean  @default(false)
  createdAt  DateTime @default(now()) @db.Timestamp(6)
  
  file       File     @relation(fields: [fileId], references: [id])
  user       User?    @relation(fields: [userId], references: [id])

  @@index([fileId])
  @@index([userId])
  @@map("downloads")
}
